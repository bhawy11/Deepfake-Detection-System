    "test_folder=\"dataset/test\"\n",
    "\n",
    "for file in os.listdir(test_folder):\n",
    "    img_path=os.path.join(test_folder,file)\n",
    "    prediction=predict_image(img_path)\n",
    "\n",
    "    if prediction is not None:\n",
    "        label=\"FAKE\" if prediction>0.5 else \"REAL\"\n",
    "        print(file,\"->\", label)"
